<Window x:Class="MuseDock.Desktop.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MuseDock.Desktop"
        xmlns:models="clr-namespace:MuseDock.Desktop.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="MuseDock"
        Width="1540"
        Height="940"
        MinWidth="1280"
        MinHeight="820"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Background="#0C0F13"
        Foreground="#F2F5F7"
        ResizeMode="CanResize"
        WindowStyle="None">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="8"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <SolidColorBrush x:Key="Brush.Window" Color="#0C0F13" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#131920" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#10161C" />
    <SolidColorBrush x:Key="Brush.Control" Color="#1A2430" />
    <SolidColorBrush x:Key="Brush.ControlHover" Color="#243241" />
    <SolidColorBrush x:Key="Brush.ControlActive" Color="#1F3547" />
    <SolidColorBrush x:Key="Brush.Border" Color="#263545" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#5D7B96" />
    <SolidColorBrush x:Key="Brush.Text" Color="#F2F5F7" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#89A0B5" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#2A88D8" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="#214D72" />

    <Style x:Key="LinePanel" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style x:Key="SectionDescription" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    </Style>

    <Style TargetType="ScrollViewer">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="ScrollBarThumbBaseStyle" TargetType="Thumb">
      <Setter Property="Background" Value="#AFC2D2" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="ThumbBorder"
                    Margin="1"
                    Background="{TemplateBinding Background}"
                    CornerRadius="4"
                    Opacity="0.96" />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ThumbBorder" Property="Background" Value="#C7D7E4" />
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="ThumbBorder" Property="Background" Value="#D7E4EE" />
                <Setter TargetName="ThumbBorder" Property="Opacity" Value="1" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="VerticalScrollBarThumbStyle"
           TargetType="Thumb"
           BasedOn="{StaticResource ScrollBarThumbBaseStyle}">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Width" Value="8" />
    </Style>

    <Style x:Key="HorizontalScrollBarThumbStyle"
           TargetType="Thumb"
           BasedOn="{StaticResource ScrollBarThumbBaseStyle}">
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="Height" Value="8" />
    </Style>

    <Style x:Key="ScrollBarButtonStyle" TargetType="RepeatButton">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RepeatButton">
            <Border Background="Transparent" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
      <Border Width="10"
              Background="#182029"
              BorderBrush="#243140"
              BorderThickness="1"
              CornerRadius="5">
        <Track x:Name="PART_Track"
               Margin="1"
               Focusable="False"
               IsDirectionReversed="True"
               Minimum="{TemplateBinding Minimum}"
               Maximum="{TemplateBinding Maximum}"
               Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Mode=TwoWay}"
               ViewportSize="{TemplateBinding ViewportSize}">
          <Track.DecreaseRepeatButton>
            <RepeatButton Style="{StaticResource ScrollBarButtonStyle}"
                          Command="ScrollBar.PageUpCommand" />
          </Track.DecreaseRepeatButton>
          <Track.Thumb>
            <Thumb Style="{StaticResource VerticalScrollBarThumbStyle}" />
          </Track.Thumb>
          <Track.IncreaseRepeatButton>
            <RepeatButton Style="{StaticResource ScrollBarButtonStyle}"
                          Command="ScrollBar.PageDownCommand" />
          </Track.IncreaseRepeatButton>
        </Track>
      </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
      <Border Height="10"
              Background="#182029"
              BorderBrush="#243140"
              BorderThickness="1"
              CornerRadius="5">
        <Track x:Name="PART_Track"
               Margin="1"
               Focusable="False"
               Orientation="Horizontal"
               Minimum="{TemplateBinding Minimum}"
               Maximum="{TemplateBinding Maximum}"
               Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Value, Mode=TwoWay}"
               ViewportSize="{TemplateBinding ViewportSize}">
          <Track.DecreaseRepeatButton>
            <RepeatButton Style="{StaticResource ScrollBarButtonStyle}"
                          Command="ScrollBar.PageLeftCommand" />
          </Track.DecreaseRepeatButton>
          <Track.Thumb>
            <Thumb Style="{StaticResource HorizontalScrollBarThumbStyle}" />
          </Track.Thumb>
          <Track.IncreaseRepeatButton>
            <RepeatButton Style="{StaticResource ScrollBarButtonStyle}"
                          Command="ScrollBar.PageRightCommand" />
          </Track.IncreaseRepeatButton>
        </Track>
      </Border>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Height" Value="10" />
          <Setter Property="MinHeight" Value="10" />
          <Setter Property="Margin" Value="0,2,0,0" />
          <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
        </Trigger>
        <Trigger Property="Orientation" Value="Vertical">
          <Setter Property="Width" Value="10" />
          <Setter Property="MinWidth" Value="10" />
          <Setter Property="Margin" Value="2,0,0,0" />
          <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="Button">
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Background" Value="{StaticResource Brush.Control}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="0.8" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.ControlHover}" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.ControlActive}" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Width" Value="34" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="WindowButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Width" Value="34" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="8,0,0,0" />
    </Style>

    <Style x:Key="TabCloseButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Width" Value="18" />
      <Setter Property="MinWidth" Value="18" />
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="TagButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="Margin" Value="6,0,0,0" />
      <Setter Property="FontSize" Value="10" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="0.8" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="CaretBrush" Value="{StaticResource Brush.Text}" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
      <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <Border x:Name="ComboBorder"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="8">
                <Grid>
                  <ContentPresenter Margin="10,0,34,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                  <ToggleButton x:Name="DropDownToggle"
                                Width="28"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                ClickMode="Press"
                                IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Brush.TextMuted}"
                               Text="▼" />
                  </ToggleButton>
                </Grid>
              </Border>
              <Popup x:Name="PART_Popup"
                     Placement="Bottom"
                     AllowsTransparency="True"
                     Focusable="False"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     PopupAnimation="Fade">
                <Border Margin="0,4,0,0"
                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                        Background="{StaticResource Brush.SurfaceAlt}"
                        BorderBrush="{StaticResource Brush.BorderStrong}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <ScrollViewer Margin="2"
                                VerticalScrollBarVisibility="Visible"
                                CanContentScroll="True">
                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
              </Trigger>
              <Trigger Property="HasItems" Value="False">
                <Setter TargetName="PART_Popup" Property="Visibility" Value="Hidden" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="ComboItemBorder"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="ComboItemBorder" Property="Background" Value="{StaticResource Brush.ControlHover}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ComboItemBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsHighlighted" Value="True">
          <Setter Property="Background" Value="{StaticResource Brush.ControlHover}" />
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{StaticResource Brush.AccentSoft}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="TreeExpanderToggle" TargetType="ToggleButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border Background="Transparent">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TreeView">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
      <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
    </Style>

    <Style TargetType="TreeViewItem">
      <Setter Property="Padding" Value="3" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
      <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
      <EventSetter Event="Expanded" Handler="DirectoryTreeItem_Expanded" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TreeViewItem">
            <StackPanel>
              <Border x:Name="TreeItemBorder"
                      Background="Transparent"
                      Padding="4,3"
                      CornerRadius="6">
                <DockPanel>
                  <ToggleButton x:Name="Expander"
                                DockPanel.Dock="Left"
                                Width="16"
                                Height="16"
                                Margin="0,0,6,0"
                                Style="{StaticResource TreeExpanderToggle}"
                                IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                    <TextBlock x:Name="ExpanderGlyph"
                               Text="▸"
                               Foreground="{StaticResource Brush.TextMuted}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </ToggleButton>
                  <ContentPresenter ContentSource="Header" />
                </DockPanel>
              </Border>
              <ItemsPresenter x:Name="ItemsHost"
                              Margin="18,2,0,0"
                              Visibility="Collapsed" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="HasItems" Value="False">
                <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
              </Trigger>
              <Trigger Property="IsExpanded" Value="True">
                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                <Setter TargetName="ExpanderGlyph" Property="Text" Value="▾" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TreeItemBorder" Property="Background" Value="{StaticResource Brush.ControlHover}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TreeItemBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                <Setter TargetName="TreeItemBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                <Setter TargetName="TreeItemBorder" Property="BorderThickness" Value="1" />
              </Trigger>
              <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <HierarchicalDataTemplate DataType="{x:Type models:DirectoryTreeNode}" ItemsSource="{Binding Children}">
      <TextBlock Text="{Binding Label}" />
    </HierarchicalDataTemplate>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal">
              <Border x:Name="CheckBorder"
                      Width="16"
                      Height="16"
                      Margin="0,0,8,0"
                      Background="{StaticResource Brush.SurfaceAlt}"
                      BorderBrush="{StaticResource Brush.BorderStrong}"
                      BorderThickness="1"
                      CornerRadius="4">
                <TextBlock x:Name="CheckMark"
                           Text="✓"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Text}"
                           FontSize="11"
                           Visibility="Collapsed" />
              </Border>
              <ContentPresenter VerticalAlignment="Center" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CheckBorder" Property="Background" Value="{StaticResource Brush.Accent}" />
                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style TargetType="ListBoxItem">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="ItemBorder"
                    Background="Transparent"
                    Padding="{TemplateBinding Padding}"
                    CornerRadius="6">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.ControlHover}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TabStripListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="TabStripBorder"
                    Background="{StaticResource Brush.Control}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TabStripBorder" Property="Background" Value="{StaticResource Brush.ControlHover}" />
                <Setter TargetName="TabStripBorder" Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabStripBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                <Setter TargetName="TabStripBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ContextMenu">
      <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style TargetType="MenuItem">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
      <Setter Property="Padding" Value="8,6" />
      <Style.Triggers>
        <Trigger Property="IsHighlighted" Value="True">
          <Setter Property="Background" Value="{StaticResource Brush.ControlHover}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="Separator">
      <Setter Property="Margin" Value="4" />
      <Setter Property="Background" Value="{StaticResource Brush.Border}" />
    </Style>

    <Style TargetType="TabControl">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
      <Setter Property="Background" Value="{StaticResource Brush.Control}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
          <Setter Property="Background" Value="{StaticResource Brush.AccentSoft}" />
          <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="GridLinesVisibility" Value="None" />
      <Setter Property="RowHeaderWidth" Value="0" />
      <Setter Property="AutoGenerateColumns" Value="False" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="CanUserDeleteRows" Value="False" />
      <Setter Property="CanUserResizeRows" Value="False" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
      <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="EnableRowVirtualization" Value="True" />
      <Setter Property="CanUserResizeColumns" Value="True" />
      <Setter Property="SelectionMode" Value="Single" />
      <Setter Property="SelectionUnit" Value="FullRow" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
      <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DataGridCell">
            <Border Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsHidden}" Value="True">
          <Setter Property="Opacity" Value="0.72" />
        </DataTrigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource Brush.ControlHover}" />
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{StaticResource Brush.AccentSoft}" />
          <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="WorkspaceTabHeaderTemplate" DataType="{x:Type models:ExplorerTabState}">
      <Border Background="Transparent"
              Cursor="SizeAll"
              PreviewMouseLeftButtonDown="TabHeader_PreviewMouseLeftButtonDown"
              PreviewMouseMove="TabHeader_PreviewMouseMove">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="{Binding Title}"
                     VerticalAlignment="Center" />
          <Button Style="{StaticResource TabCloseButton}"
                  Tag="{Binding}"
                  Click="CloseTab_Click"
                  Content="×" />
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="WorkspaceTabContentTemplate" DataType="{x:Type models:ExplorerTabState}">
      <Grid Background="Transparent"
            MinHeight="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="12,0,12,10"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,14,0"
                        VerticalAlignment="Center">
              <TextBlock FontSize="16"
                         FontWeight="SemiBold"
                         Text="{Binding CurrentLocationName}" />
              <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                         Text="{Binding ResultSummary}" />
            </StackPanel>

            <TextBox Grid.Column="1"
                     Margin="0,0,10,0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="名前、タグ、メモで検索" />

            <ComboBox Grid.Column="2"
                      Width="120"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding TypeFilters}"
                      SelectedItem="{Binding SelectedTypeFilter}" />

            <ComboBox Grid.Column="3"
                      Width="120"
                      Margin="0,0,10,0"
                      ItemsSource="{Binding GroupingOptions}"
                      SelectedItem="{Binding SelectedGroupingOption}" />

            <CheckBox Grid.Column="4"
                      IsChecked="{Binding FavoritesOnly}"
                      Content="お気に入りのみ" />
          </Grid>
        </Border>

        <DataGrid Grid.Row="1"
                  MinHeight="0"
                  Margin="12,8,12,12"
                  ItemsSource="{Binding AssetsView}"
                  SelectedItem="{Binding SelectedAsset, Mode=TwoWay}"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  Loaded="AssetGrid_Loaded"
                  Unloaded="AssetGrid_Unloaded"
                  ScrollViewer.PanningMode="Both"
                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  MouseDoubleClick="AssetListBox_MouseDoubleClick"
                  PreviewMouseDown="AssetGrid_PreviewMouseDown"
                  PreviewMouseRightButtonDown="AssetGrid_PreviewMouseRightButtonDown"
                  ContextMenuOpening="AssetGrid_ContextMenuOpening">
          <DataGrid.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
                  <Border Margin="0,8,0,4"
                          Padding="8,6"
                          Background="{StaticResource Brush.Control}"
                          BorderBrush="{StaticResource Brush.Border}"
                          BorderThickness="1"
                          CornerRadius="6">
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding Name}" />
                  </Border>
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </DataGrid.GroupStyle>
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="名前"
                                    Width="320"
                                    MinWidth="220">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <Image Width="16"
                           Height="16"
                           Margin="0,0,8,0"
                           Source="{Binding IconSource}" />
                    <TextBlock Text="{Binding Name}"
                               VerticalAlignment="Center" />
                    <Border Margin="8,0,0,0"
                            Padding="6,1"
                            Background="{StaticResource Brush.Control}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="5">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHidden}" Value="True">
                              <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock FontSize="10"
                                 Foreground="{StaticResource Brush.TextMuted}"
                                 Text="隠し" />
                    </Border>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="種類"
                                Width="120"
                                MinWidth="90"
                                Binding="{Binding KindLabel, Mode=OneWay}" />
            <DataGridTextColumn Header="更新日時"
                                Width="180"
                                MinWidth="140"
                                Binding="{Binding ModifiedDisplay, Mode=OneWay}" />
            <DataGridTextColumn Header="サイズ"
                                Width="120"
                                MinWidth="90"
                                Binding="{Binding SizeDisplay, Mode=OneWay}" />
            <DataGridTextColumn Header="タグ"
                                Width="220"
                                MinWidth="120"
                                Binding="{Binding TagsDisplay, Mode=OneWay}" />
            <DataGridTextColumn Header="★"
                                Width="60"
                                Binding="{Binding FavoriteMark, Mode=OneWay}" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="WorkspacePaneTemplate" DataType="{x:Type models:WorkspacePaneState}">
      <Border Background="{StaticResource Brush.SurfaceAlt}"
              MinHeight="0"
              PreviewMouseLeftButtonDown="WorkspacePane_MouseDown"
              AllowDrop="True"
              PreviewDragEnter="WorkspacePane_DragEnter"
              PreviewDragOver="WorkspacePane_DragOver"
              PreviewDragLeave="WorkspacePane_DragLeave"
              PreviewDrop="WorkspacePane_Drop">
        <Grid MinHeight="0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <ListBox Grid.Row="0"
                   Margin="10,10,10,0"
                   ItemsSource="{Binding Tabs}"
                   SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                   Loaded="WorkspaceTabControl_Loaded"
                   SelectionChanged="WorkspaceTabControl_SelectionChanged"
                   ItemTemplate="{StaticResource WorkspaceTabHeaderTemplate}"
                   ItemContainerStyle="{StaticResource TabStripListBoxItemStyle}"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
          </ListBox>

          <ContentControl Grid.Row="1"
                          Margin="0,8,0,0"
                          MinHeight="0"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding SelectedTab}"
                          ContentTemplate="{StaticResource WorkspaceTabContentTemplate}" />

        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Grid Background="{StaticResource Brush.Window}">
    <Grid.RowDefinitions>
      <RowDefinition Height="52" />
      <RowDefinition Height="*" />
      <RowDefinition Height="120" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="{StaticResource Brush.Window}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,0,0,1">
      <Grid Margin="12,8,12,8"
            MouseLeftButtonDown="Toolbar_MouseLeftButtonDown">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Image Width="18"
               Height="18"
               Margin="0,0,10,0"
               Source="pack://application:,,,/Assets/AppIcon.png" />

        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="MuseDock" />

        <StackPanel Grid.Column="2"
                    Margin="18,0,14,0"
                    Orientation="Horizontal">
          <Button Style="{StaticResource IconButton}"
                  Click="Back_Click"
                  IsEnabled="{Binding SelectedTab.CanGoBack}"
                  ToolTip="戻る"
                  Content="←" />
          <Button Style="{StaticResource IconButton}"
                  Click="Forward_Click"
                  IsEnabled="{Binding SelectedTab.CanGoForward}"
                  ToolTip="進む"
                  Content="→" />
          <Button Style="{StaticResource IconButton}"
                  Click="Up_Click"
                  IsEnabled="{Binding SelectedTab.CanGoUp}"
                  ToolTip="上へ"
                  Content="↑" />
          <Button Style="{StaticResource IconButton}"
                  Click="RenameSelected_Click"
                  IsEnabled="{Binding SelectedTab.HasSelection}"
                  ToolTip="名前変更"
                  Content="✎" />
        </StackPanel>

        <Button Grid.Column="3"
                Margin="0,0,14,0"
                Click="OpenSettings_Click"
                Content="設定" />

        <Grid Grid.Column="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Border Background="{StaticResource Brush.SurfaceAlt}"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1"
                  CornerRadius="8">
            <TextBlock Margin="10,6"
                       VerticalAlignment="Center"
                       Text="{Binding SelectedTab.CurrentLocationPath}"
                       TextTrimming="CharacterEllipsis" />
          </Border>
          <TextBlock Grid.Column="1"
                     Margin="12,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource Brush.TextMuted}"
                     Text="{Binding SelectedTab.StatusText}" />
        </Grid>

        <StackPanel Grid.Column="5"
                    Margin="14,0,0,0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button Style="{StaticResource WindowButton}"
                  Click="Minimize_Click"
                  Content="＿" />
          <Button Style="{StaticResource WindowButton}"
                  Click="ToggleMaximize_Click"
                  Content="□" />
          <Button Style="{StaticResource WindowButton}"
                  Click="CloseWindow_Click"
                  Content="✕" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          MinHeight="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="250" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="320" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0"
            Background="{StaticResource Brush.Surface}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="12,10,12,8"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionLabel}"
                       Text="クイックアクセスとディレクトリ" />
            <TextBlock Style="{StaticResource SectionDescription}"
                       Text="グループ登録したフォルダーや左側のツリーからすぐ開けます。" />
          </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Padding="10,10,10,8"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
          <StackPanel>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Button Grid.Column="0"
                      Padding="10,4"
                      Click="AddQuickAccessGroup_Click"
                      Content="+ グループ" />
              <ComboBox Grid.Column="1"
                        Margin="8,0"
                        ItemsSource="{Binding QuickAccessGroups}"
                        DisplayMemberPath="Name"
                        SelectedItem="{Binding SelectedQuickAccessGroup, Mode=TwoWay}" />
              <Button Grid.Column="2"
                      Padding="10,4"
                      Click="AddCurrentFolderToQuickAccess_Click"
                      Content="+ 選択フォルダー" />
            </Grid>

            <ItemsControl ItemsSource="{Binding QuickAccessGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:QuickAccessGroup}">
                  <Border Margin="0,0,0,8"
                          Padding="8"
                          Background="{StaticResource Brush.SurfaceAlt}"
                          BorderBrush="{StaticResource Brush.Border}"
                          BorderThickness="1"
                          CornerRadius="8">
                    <StackPanel>
                      <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock FontSize="11"
                                     Foreground="{StaticResource Brush.TextMuted}"
                                     Text="{Binding FolderCount, StringFormat=登録フォルダー {0} 件}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="8,2"
                                Tag="{Binding}"
                                Click="RenameQuickAccessGroup_Click"
                                Content="名前変更" />
                        <Button Grid.Column="2"
                                Margin="6,0,0,0"
                                Padding="8,2"
                                Tag="{Binding}"
                                Click="DeleteQuickAccessGroup_Click"
                                Content="削除" />
                      </Grid>

                      <ItemsControl ItemsSource="{Binding Folders}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="{x:Type models:QuickAccessFolder}">
                            <Grid Margin="0,0,0,4">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <Button Grid.Column="0"
                                      HorizontalContentAlignment="Left"
                                      Tag="{Binding}"
                                      Click="OpenQuickAccessFolder_Click"
                                      Content="{Binding Label}"
                                      ToolTip="{Binding Path}" />
                              <Button Grid.Column="1"
                                      Margin="6,0,0,0"
                                      Padding="8,2"
                                      CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                      Tag="{Binding}"
                                      Click="RemoveQuickAccessFolder_Click"
                                      Content="×" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <TreeView Grid.Row="2"
                  Margin="8"
                  ItemsSource="{Binding DirectoryRoots}"
                  SelectedItemChanged="DirectoryTree_SelectedItemChanged" />
      </Grid>

      <Border Grid.Column="1"
              Background="{StaticResource Brush.Border}" />

      <Grid Grid.Column="2"
            MinHeight="0"
            Background="{StaticResource Brush.SurfaceAlt}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="12,10,12,8"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Style="{StaticResource SectionLabel}"
                         Text="ワークスペース" />
              <TextBlock Style="{StaticResource SectionDescription}"
                         Text="タブを切り替えながらフォルダーを並行して開けます。" />
            </StackPanel>
            <Button Grid.Column="1"
                    Click="NewTab_Click"
                    Content="+ 新しいタブ" />
          </Grid>
        </Border>

        <Grid Grid.Row="1"
              MinHeight="0"
              Margin="12,10,12,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="WorkspaceColumn0"
                              Width="*" />
            <ColumnDefinition x:Name="WorkspaceDividerColumn01"
                              Width="0" />
            <ColumnDefinition x:Name="WorkspaceColumn1"
                              Width="0" />
            <ColumnDefinition x:Name="WorkspaceDividerColumn12"
                              Width="0" />
            <ColumnDefinition x:Name="WorkspaceColumn2"
                              Width="0" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition x:Name="WorkspaceRow0"
                           Height="*" />
            <RowDefinition x:Name="WorkspaceDividerRow01"
                           Height="0" />
            <RowDefinition x:Name="WorkspaceRow1"
                           Height="0" />
            <RowDefinition x:Name="WorkspaceDividerRow12"
                           Height="0" />
            <RowDefinition x:Name="WorkspaceRow2"
                           Height="0" />
          </Grid.RowDefinitions>

          <ContentControl x:Name="WorkspacePane0Host"
                          Grid.Row="0"
                          Grid.Column="0"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace0}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}" />

          <Border x:Name="WorkspaceVerticalDivider01"
                  Grid.Row="0"
                  Grid.RowSpan="5"
                  Grid.Column="1"
                  Background="{StaticResource Brush.Border}"
                  Visibility="Collapsed" />

          <Border x:Name="WorkspaceVerticalDivider12"
                  Grid.Row="0"
                  Grid.RowSpan="5"
                  Grid.Column="3"
                  Background="{StaticResource Brush.Border}"
                  Visibility="Collapsed" />

          <Border x:Name="WorkspaceHorizontalDivider01"
                  Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="5"
                  Background="{StaticResource Brush.Border}"
                  Visibility="Collapsed" />

          <ContentControl x:Name="WorkspacePane1Host"
                          Grid.Row="0"
                          Grid.Column="2"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace1}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}"
                          Visibility="Collapsed" />

          <ContentControl x:Name="WorkspacePane2Host"
                          Grid.Row="0"
                          Grid.Column="4"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace2}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}"
                          Visibility="Collapsed" />

          <ContentControl x:Name="WorkspacePane3Host"
                          Grid.Row="2"
                          Grid.Column="0"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace3}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}"
                          Visibility="Collapsed" />

          <ContentControl x:Name="WorkspacePane4Host"
                          Grid.Row="2"
                          Grid.Column="2"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace4}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}"
                          Visibility="Collapsed" />

          <ContentControl x:Name="WorkspacePane5Host"
                          Grid.Row="2"
                          Grid.Column="4"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace5}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}"
                          Visibility="Collapsed" />

          <Border x:Name="WorkspaceHorizontalDivider12"
                  Grid.Row="3"
                  Grid.Column="0"
                  Grid.ColumnSpan="5"
                  Background="{StaticResource Brush.Border}"
                  Visibility="Collapsed" />

          <ContentControl x:Name="WorkspacePane6Host"
                          Grid.Row="4"
                          Grid.Column="0"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace6}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}"
                          Visibility="Collapsed" />

          <ContentControl x:Name="WorkspacePane7Host"
                          Grid.Row="4"
                          Grid.Column="2"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace7}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}"
                          Visibility="Collapsed" />

          <ContentControl x:Name="WorkspacePane8Host"
                          Grid.Row="4"
                          Grid.Column="4"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch"
                          Content="{Binding Workspace8}"
                          ContentTemplate="{StaticResource WorkspacePaneTemplate}"
                          Visibility="Collapsed" />

          <Border Grid.Row="0"
                  Grid.RowSpan="5"
                  Grid.Column="0"
                  Grid.ColumnSpan="5"
                  Panel.ZIndex="30"
                  Margin="12"
                  IsHitTestVisible="False"
                  Background="#CC0F151C"
                  BorderBrush="{StaticResource Brush.Accent}"
                  BorderThickness="1"
                  CornerRadius="14">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsWorkspaceDropOverlayVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid Margin="16">
              <Grid.RowDefinitions>
                <RowDefinition Height="0.25*" />
                <RowDefinition Height="0.5*" />
                <RowDefinition Height="0.25*" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.25*" />
                <ColumnDefinition Width="0.5*" />
                <ColumnDefinition Width="0.25*" />
              </Grid.ColumnDefinitions>

              <Border Grid.RowSpan="3"
                      Grid.Column="0"
                      CornerRadius="12"
                      Background="#66398BD1">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding WorkspaceDropOverlayKey}" Value="Left">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
              </Border>

              <Border Grid.RowSpan="3"
                      Grid.Column="2"
                      CornerRadius="12"
                      Background="#66398BD1">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding WorkspaceDropOverlayKey}" Value="Right">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
              </Border>

              <Border Grid.Row="0"
                      Grid.ColumnSpan="3"
                      CornerRadius="12"
                      Background="#66398BD1">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding WorkspaceDropOverlayKey}" Value="Top">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
              </Border>

              <Border Grid.Row="2"
                      Grid.ColumnSpan="3"
                      CornerRadius="12"
                      Background="#66398BD1">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding WorkspaceDropOverlayKey}" Value="Bottom">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
              </Border>

              <Border Grid.Row="1"
                      Grid.Column="1"
                      CornerRadius="12"
                      Background="#664C6175">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding WorkspaceDropOverlayKey}" Value="Center">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
              </Border>

              <TextBlock Grid.RowSpan="3"
                         Grid.ColumnSpan="3"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Text="{Binding WorkspaceDropOverlayText}" />
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Border Grid.Column="3"
              Background="{StaticResource Brush.Border}" />

      <Grid Grid.Column="4"
            Background="{StaticResource Brush.Surface}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="12,10,12,8"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionLabel}"
                       Text="詳細" />
            <TextBlock Style="{StaticResource SectionDescription}"
                       Text="選択した項目のプレビューと情報を表示します。" />
          </StackPanel>
        </Border>

        <Grid Grid.Row="1">
          <Border Padding="16">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedTab.HasSelection}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock VerticalAlignment="Center"
                       Foreground="{StaticResource Brush.TextMuted}"
                       Text="ファイルを選択してください。"
                       TextWrapping="Wrap" />
          </Border>

          <ScrollViewer Padding="12"
                        VerticalScrollBarVisibility="Visible">
            <ScrollViewer.Style>
              <Style TargetType="ScrollViewer">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedTab.HasSelection}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ScrollViewer.Style>
            <StackPanel DataContext="{Binding SelectedTab}">
              <Border Height="220"
                      Margin="0,0,0,12"
                      Background="{StaticResource Brush.SurfaceAlt}"
                      BorderBrush="{StaticResource Brush.Border}"
                      BorderThickness="1"
                      CornerRadius="10">
                <Grid>
                  <Image Stretch="Uniform"
                         Source="{Binding PreviewImagePath}"
                         Visibility="{Binding IsImagePreviewVisible, Converter={StaticResource BoolToVisibility}}" />
                  <MediaElement Source="{Binding PreviewVideoUri}"
                                LoadedBehavior="Play"
                                UnloadedBehavior="Stop"
                                Stretch="Uniform"
                                Visibility="{Binding IsVideoPreviewVisible, Converter={StaticResource BoolToVisibility}}" />
                  <ScrollViewer Visibility="{Binding IsTextPreviewVisible, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Margin="12"
                               FontFamily="Consolas"
                               Text="{Binding PreviewText}"
                               TextWrapping="Wrap" />
                  </ScrollViewer>
                  <TextBlock Margin="16"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource Brush.TextMuted}"
                             Text="{Binding PreviewFallbackText}"
                             TextWrapping="Wrap"
                             Visibility="{Binding IsFallbackPreviewVisible, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
              </Border>

              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Text="{Binding SelectedAsset.Name}" />
              <TextBlock Margin="0,4,0,12"
                         Foreground="{StaticResource Brush.TextMuted}"
                         Text="{Binding SelectedAsset.FilePath}"
                         TextWrapping="Wrap" />

              <UniformGrid Margin="0,0,0,12"
                           Columns="2">
                <StackPanel Margin="0,0,12,8">
                  <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                             Text="種類" />
                  <TextBlock Text="{Binding SelectedAsset.KindLabel}" />
                </StackPanel>
                <StackPanel Margin="0,0,0,8">
                  <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                             Text="サイズ" />
                  <TextBlock Text="{Binding SelectedAsset.SizeDisplay}" />
                </StackPanel>
                <StackPanel Margin="0,0,12,8">
                  <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                             Text="場所" />
                  <TextBlock Text="{Binding SelectedAsset.RelativeDirectoryDisplay}" />
                </StackPanel>
                <StackPanel Margin="0,0,0,8">
                  <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                             Text="更新日時" />
                  <TextBlock Text="{Binding SelectedAsset.ModifiedDisplay}" />
                </StackPanel>
              </UniformGrid>

              <CheckBox Margin="0,0,0,12"
                        IsChecked="{Binding SelectedAsset.IsFavorite}"
                        Checked="FavoriteToggle_Changed"
                        Unchecked="FavoriteToggle_Changed"
                        Content="お気に入り" />

              <TextBlock Margin="0,0,0,6"
                         FontWeight="SemiBold"
                         Text="タグ" />
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding PendingTagText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Click="AddTag_Click"
                        Content="追加" />
              </Grid>

              <ItemsControl Margin="0,0,0,12"
                            ItemsSource="{Binding SelectedAsset.Tags}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,6,6"
                            Background="{StaticResource Brush.AccentSoft}"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,4">
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding}" />
                        <Button Style="{StaticResource TagButton}"
                                Click="RemoveTag_Click"
                                Content="×" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Margin="0,0,0,6"
                         FontWeight="SemiBold"
                         Text="メモ" />
              <TextBox AcceptsReturn="True"
                       MinHeight="120"
                       Text="{Binding SelectedAsset.Note, UpdateSourceTrigger=PropertyChanged}"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Visible"
                       LostFocus="NoteEditor_LostFocus" />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Grid>
    </Grid>

    <Border Grid.Row="2"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,1,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="12,10,12,8"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionLabel}"
                       Text="アクティビティ" />
            <TextBlock Style="{StaticResource SectionDescription}"
                       Text="ファイル操作と読み込み状況を表示します。" />
          </StackPanel>
        </Border>

        <ListBox Grid.Row="1"
                 Margin="8,6,8,8"
                 ItemsSource="{Binding ActivityLog}" />
      </Grid>
    </Border>
  </Grid>
</Window>
